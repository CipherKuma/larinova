# =============================================================================
# Larinova Workspace — Root .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS — never commit
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.cert
*.crt

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
.next/
.turbo/
.vercel/
out/
build/
dist/

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# Logs & debug
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Editor & OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
!.vscode/settings.shared.json
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Playwright / MCP / AI scratch
# -----------------------------------------------------------------------------
.playwright-data/
.playwright-mcp/
.superpowers/brainstorm/

# -----------------------------------------------------------------------------
# Supabase ephemeral
# -----------------------------------------------------------------------------
**/supabase/.temp/
**/supabase/.branches/

# -----------------------------------------------------------------------------
# Next.js / TypeScript
# -----------------------------------------------------------------------------
next-env.d.ts
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Claude Code local settings
# -----------------------------------------------------------------------------
.claude/settings.local.json

# -----------------------------------------------------------------------------
# This repo's own backups (kept outside working tree)
# -----------------------------------------------------------------------------
/subrepo-git-backups/

# -----------------------------------------------------------------------------
# Stashed sub-repo .git folders (left in-place because sandbox couldn't delete)
# -----------------------------------------------------------------------------
**/.git-stashed/
